# ============================================================
# NGROK — Local Development Tunnel
# ============================================================
# Required to expose localhost:3000 to the internet so Paystack
# can reach the webhook at /api/subscribe/webhook.
#
# Setup (one-off):
#   1. Create a free account at https://ngrok.com
#   2. Copy your auth token from: Dashboard → Your Authtoken
#   3. Set NGROK_AUTHTOKEN below
#   4. Run: npm run tunnel     (in a second terminal alongside npm run dev)
#
# Static domain (strongly recommended — free):
#   Claim one at: https://dashboard.ngrok.com/domains → New Domain
#   This gives you a permanent URL so you only register it in Paystack once.
#   Without it, the URL changes every restart and must be re-registered.
#
NGROK_AUTHTOKEN=
NGROK_DOMAIN=                   # e.g. your-name.ngrok-free.app (leave blank for random URL)

# ============================================================
# GEMINI AI
# ============================================================
# Required for the Monty chatbot (server-side only, never exposed to browser).
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ============================================================
# RESEND — Transactional Email
# ============================================================
# Required for all form submission emails (Contact, POS, Assessments).
# Obtain from: https://resend.com → API Keys
#
# Domain verification (one-time setup):
#   1. resend.com → Domains → Add Domain → enter "montanadc.com"
#   2. Add the 3 DNS records provided (SPF, DKIM, DMARC) to your DNS provider
#   3. Click Verify — propagation takes 5–60 minutes
# Until verified, Resend delivers from onboarding@resend.dev instead.
RESEND_API_KEY="re_LPPPhffQ_D79cdzwMi15xoCYXza2S7Rd3"

# ============================================================
# APP
# ============================================================
# Public URL used in email call-to-action links.
# Development: http://localhost:3000
APP_URL="https://montanadc.com"

# ============================================================
# MONDAY.COM — CRM Integration
# ============================================================
# Required to create leads/items in monday.com from all web forms.
# Obtain your API key from: monday.com → Profile → Developers → API
#
# ── HOW TO FIND A BOARD ID ──────────────────────────────────
#   Open the board in monday.com → look at the URL:
#   https://montanadc.monday.com/boards/1234567890  →  ID = 1234567890
#
# ── HOW TO FIND A COLUMN ID ─────────────────────────────────
#   Board → click a column header → Settings (⚙) → "Edit Column"
#   The column ID is shown at the bottom of the panel.
#   If your IDs differ from the defaults in lib/monday.ts, update the
#   CONTACT_COLS / POS_COLS / ASSESSMENT_COLS constants in that file.
#
# ─────────────────────────────────────────────────────────────
# BOARD 1 — "Website Leads"  →  MONDAY_CONTACT_BOARD_ID
#
#   Create a new board named "Website Leads" with these columns IN THIS ORDER:
#   (The order determines the auto-assigned column IDs)
#
#   Column name      Type         Expected ID   Status labels (exact text)
#   ──────────────── ──────────── ───────────── ──────────────────────────────────────────
#   Email            Email        email         —
#   Company          Short Text   text          —
#   Enquiry Type     Status       status        New Solution | Existing Client |
#                                               Partnership | POPIA Consulting | General
#   Message          Long Text    long_text     —
#   Lead Status      Status       status_1      New Lead | Contacted | Qualified |
#                                               Proposal Sent | Won | Lost
#
MONDAY_CONTACT_BOARD_ID="5094032848"

# ─────────────────────────────────────────────────────────────
# BOARD 2 — "Solution Requests"  →  MONDAY_POS_BOARD_ID
#
#   Column name      Type         Expected ID   Status labels
#   ──────────────── ──────────── ───────────── ──────────────────────────────────────
#   Email            Email        email         —
#   Company          Short Text   text          —
#   Services         Long Text    long_text     —
#   Notes            Long Text    long_text_1   —
#   Lead Status      Status       status        New Request | Scoping |
#                                               Proposal Sent | Won | Lost
#
MONDAY_POS_BOARD_ID="5094033428"

# ─────────────────────────────────────────────────────────────
# BOARD 3 — "Assessment Leads"  →  MONDAY_ASSESSMENT_BOARD_ID
#
#   Column name      Type         Expected ID   Status labels
#   ──────────────── ──────────── ───────────── ──────────────────────────────────────
#   Email            Email        email         —
#   Company          Short Text   text          —
#   Assessment Type  Status       status        Security & Backup | POPIA Compliance
#   Score            Numbers      numbers       —
#   Risk Level       Status       status_1      High Risk | Moderate Risk |
#                                               Medium Risk | Low Risk
#   Lead Status      Status       status_2      New Lead | Contacted | Qualified |
#                                               Proposal Sent | Won | Lost
#
MONDAY_ASSESSMENT_BOARD_ID="5094033566"

# ─────────────────────────────────────────────────────────────
# BOARD 4 — "Support Tickets"  →  MONDAY_SUPPORT_BOARD_ID
#
#   Column name      Type         Expected ID   Status labels
#   ──────────────── ──────────── ───────────── ──────────────────────────────────────
#   Email            Email        email         —
#   Company          Short Text   text          —
#   Category         Status       status        Technical | Billing | Compliance | General
#   Priority         Status       status_1      Low | Normal | High | Critical
#   Message          Long Text    long_text     —
#   Ticket Status    Status       status_2      New | In Progress | Awaiting Client |
#                                               Resolved | Closed
#
MONDAY_SUPPORT_BOARD_ID=

# ─────────────────────────────────────────────────────────────
# BOARD 5 — "Website - Solution Requests FULL"  →  MONDAY_ORDERS_BOARD_ID
#
# Monday.com Orders Board (Website - Solution Requests FULL)
MONDAY_ORDERS_BOARD_ID=5094739911

# ── API KEY ──────────────────────────────────────────────────
# Profile (avatar top-right) → Developers → My Access Tokens → Copy
MONDAY_API_KEY="your-monday-api-key"

# ============================================================
# SUPABASE
# ============================================================
# Project URL — Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role key — SERVER-SIDE ONLY, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# PAYSTACK
# ============================================================
# Public key — from Paystack Dashboard → Settings → API Keys
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Secret key — SERVER-SIDE ONLY
PAYSTACK_SECRET_KEY=

# ============================================================
# SAGE BUSINESS CLOUD
# ============================================================
# Bearer token for Sage Accounting REST API
SAGE_API_KEY=

# ============================================================
# DISCOUNT CODES
# ============================================================
# JSON object mapping uppercase code → discount percentage (1–100)
# Used by processOrder (checkout) to apply partner/promo discounts.
# Example: {"PARTNER15":15,"PROMO20":20}
DISCOUNT_CODES=

# Site/company ID from Sage dashboard
SAGE_SITE_ID=
